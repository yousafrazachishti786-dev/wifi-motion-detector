# WiFi Motion Detector Configuration

# WiFi Interface
WIFI_INTERFACE=wlan0

# Detection Settings
THRESHOLD=3
WINDOW_SIZE=10
INTERVAL=1

# GPIO Settings (Raspberry Pi)
ALERT_ENABLED=false
GPIO_PIN=17

# MQTT Settings (Optional)
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=home/motion
MQTT_ENABLED=false
